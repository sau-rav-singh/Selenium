<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Define timestamp property -->
    <timestamp key="timestamp" datePattern="yyyy-MM-dd_HH-mm-ss"/>

    <!-- Console Appender -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- File Appender with timestamp -->
    <appender name="FILE" class="ch.qos.logback.core.FileAppender">
        <file>logs/test-run-${timestamp}.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Root Logger -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
    </root>

    <!-- Package-specific log levels -->
    <logger name="listeners" level="DEBUG" />
    <logger name="driver" level="DEBUG" />
</configuration>
